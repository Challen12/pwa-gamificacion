3. Esquema de Base de Datos (Prisma)
El modelo relacional inicial cubre todas las entidades requeridas:

prisma

// prisma/schema.prisma
enum Role {
  USER
  ADMIN
}
enum Intensity {
  SUAVE
  MODERADO
  TITAN
}
model User {
  id        String   @id @default(cuid())
  username  String   @unique
  password  String   // Hash
  name      String
  role      Role     @default(USER)
  points    Float    @default(0) // Motor de puntos estricto
  coins     Int      @default(0)
  levelId   String?
  level     Level?   @relation(fields: [levelId], references: [id])
  
  activities Activity[]
  steps      Step[]
  badges     UserBadge[]
  missions   UserMission[]
  rewards    UserReward[]
}
model Activity {
  id           String    @id @default(cuid())
  userId       String
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  type         String    // Ej: Correr, Natación
  duration     Int       // Minutos (1h = 100pts)
  intensity    Intensity
  imageUrl     String?   // Ruta de la foto
  pointsEarned Float
  date         DateTime  @default(now())
}
model Step {
  id           String   @id @default(cuid())
  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  count        Int      // 1 paso = 0.0001pts
  pointsEarned Float
  date         DateTime @default(now())
}
model Reward { // Premios
  id          String   @id @default(cuid())
  name        String
  description String
  imageUrl    String?
  pointsReq   Int
  expiresAt   DateTime?
  users       UserReward[]
}
model Challenge { // Retos
  id          String   @id @default(cuid())
  name        String
  description String
  target      Int      
  pointsReq   Int
}
model Mission { // Misiones
  id          String   @id @default(cuid())
  name        String
  description String
  pointsReq   Int
  users       UserMission[]
}
model Badge { // Insignias
  id          String   @id @default(cuid())
  name        String
  description String
  imageUrl    String?
  pointsReq   Int
  users       UserBadge[]
}
model Level { // Niveles
  id          String   @id @default(cuid())
  name        String
  pointsReq   Int
  users       User[]
}
// Tablas intermedias para relación Muchos-a-Muchos
model UserBadge {
  userId  String
  badgeId String
  user    User   @relation(fields: [userId], references: [id])
  badge   Badge  @relation(fields: [badgeId], references: [id])
  @@id([userId, badgeId])
}
model UserMission {
  userId    String
  missionId String
  user      User    @relation(fields: [userId], references: [id])
  mission   Mission @relation(fields: [missionId], references: [id])
  @@id([userId, missionId])
}
model UserReward {
  userId   String
  rewardId String
  user     User   @relation(fields: [userId], references: [id])
  reward   Reward @relation(fields: [rewardId], references: [id])
  @@id([userId, rewardId])
}
4. Script Inicialización (Seed) - trabajadores.md
Aquí está la estructura base del script que se ejecutará para poblar la DB.

typescript

// prisma/seed.ts
import { PrismaClient } from '@prisma/client'
import * as fs from 'fs'
import * as path from 'path'
import bcrypt from 'bcrypt' 
const prisma = new PrismaClient()
async function main() {
  const filePath = path.join(process.cwd(), 'informacion', 'trabajadores.md')
  
  // Como actualmente el archivo está vacío, la lógica de parseLine se adaptará
  // en cuanto me proporciones el contenido.
  const fileContent = fs.readFileSync(filePath, 'utf-8')
  const lines = fileContent.split('\n').filter(l => l.trim() !== '')
  for (const line of lines) {
    const [name, username, plainPassword] = parseLine(line) 
    const hashedPassword = await bcrypt.hash(plainPassword, 10)
    await prisma.user.upsert({
      where: { username },
      update: {},
      create: {
        name,
        username,
        password: hashedPassword,
        role: 'USER', 
      },
    })
  }
  console.log('✅ Base de datos poblada exitosamente')
}
function parseLine(line: string) {
  // TODO: Ajustar al formato real de trabajadores.md
  return line.split(',').map(item => item.trim())
}
main().catch(e => { console.error(e); process.exit(1); }).finally(async () => { await prisma.$disconnect(); })

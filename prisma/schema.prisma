generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  username  String   @unique
  password  String   // Hash
  name      String
  avatarUrl String?
  role      String   @default("USER")
  points    Float    @default(0) // Motor de puntos estricto
  levelId   String?
  level     Level?   @relation(fields: [levelId], references: [id])
  
  activities Activity[]
  steps      Step[]
  badges     UserBadge[]
  missions   UserMission[]
  rewards    UserReward[]
  challenges UserChallenge[]
}

model Activity {
  id           String    @id @default(cuid())
  userId       String
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  type         String    // Ej: Correr, Natación
  duration     Int       // Minutos (1h = 100pts)
  intensity    String
  imageUrl     String?   // Ruta de la foto
  pointsEarned Float
  date         DateTime  @default(now())
}

model Step {
  id           String   @id @default(cuid())
  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  count        Int      // 1 paso = 0.0001pts
  pointsEarned Float
  date         DateTime @default(now())
}

model Reward { // Premios
  id          String   @id @default(cuid())
  name        String
  description String
  imageUrl    String?
  pointsReq   Int
  expiresAt   DateTime?
  users       UserReward[]
}

model Challenge { // Retos
  id          String   @id @default(cuid())
  name        String
  description String
  type        String   @default("pasos")
  target      Int      
  pointsReq   Int
  users       UserChallenge[]
}

model Mission { // Misiones
  id          String   @id @default(cuid())
  name        String
  description String
  pointsReq   Int
  users       UserMission[]
}

model Badge { // Insignias
  id          String   @id @default(cuid())
  name        String
  description String
  imageUrl    String?
  pointsReq   Int
  users       UserBadge[]
}

model Level { // Niveles
  id          String   @id @default(cuid())
  name        String
  pointsReq   Int
  users       User[]
}

// Tablas intermedias para relación Muchos-a-Muchos
model UserBadge {
  userId  String
  badgeId String
  user    User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  badge   Badge  @relation(fields: [badgeId], references: [id], onDelete: Cascade)
  @@id([userId, badgeId])
}

model UserMission {
  userId    String
  missionId String
  user      User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  mission   Mission @relation(fields: [missionId], references: [id], onDelete: Cascade)
  @@id([userId, missionId])
}

model UserReward {
  userId   String
  rewardId String
  user     User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  reward   Reward @relation(fields: [rewardId], references: [id], onDelete: Cascade)
  @@id([userId, rewardId])
}

model UserChallenge {
  userId      String
  challengeId String
  completedAt DateTime @default(now())
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  challenge   Challenge @relation(fields: [challengeId], references: [id], onDelete: Cascade)
  @@id([userId, challengeId])
}

model Settings {
  id                      String @id @default("global")
  pointsPerStep           Float  @default(0.001)
  pointsPerExerciseMinute Float  @default(1.6667)
}
